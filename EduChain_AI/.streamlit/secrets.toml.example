# 이 파일을 secrets.toml 로 복사한 뒤 값을 채우세요.
# secrets.toml 은 Git에 커밋하지 마세요.

GEMINI_API_KEY = ""
# (선택) 기본 모델 — 비우면 gemini-2.5-flash-lite (코드가 자동으로 다른 모델도 순서대로 시도)
# GEMINI_MODEL = "gemini-2.0-flash"
# (선택) 추가로만 쓸 모델, 쉼표 구분 (자동 폴백 목록 뒤에 이어 붙음)
# GEMINI_MODEL_FALLBACKS = "gemini-2.5-pro"

# --- Firebase Admin (Firestore 등) — 택1 ---
# FIREBASE_CREDENTIALS_PATH = "firebase-service-account.json"
# FIREBASE_SERVICE_ACCOUNT_JSON = '{"type":"service_account",...}'

# --- Firebase 웹 앱 (JS SDK firebaseConfig 와 동일 / Python에서도 재사용) ---
# 콘솔 → 프로젝트 설정 → 일반 → 내 앱(웹) → SDK 설정 및 구성
FIREBASE_WEB_API_KEY = "" # apiKey
FIREBASE_AUTH_DOMAIN = "" # *.firebaseapp.com
FIREBASE_PROJECT_ID = ""
FIREBASE_STORAGE_BUCKET = "" # *.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID = ""
FIREBASE_APP_ID = "" # 1:xxxx:web:xxxx
# Analytics 사용 시에만 (선택)
# FIREBASE_MEASUREMENT_ID = "" # G-xxxxxxxxxx
# (이메일·Google REST 로그인도 위 FIREBASE_WEB_API_KEY = apiKey 와 동일)

# --- Google OAuth (Google 로그인 시) — 필수 ---
# Google Cloud → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID → 웹 애플리케이션
GOOGLE_OAUTH_CLIENT_ID = ""
GOOGLE_OAUTH_CLIENT_SECRET = ""
# 로컬: http://localhost:8501/  |  Streamlit Cloud: https://앱이름.streamlit.app/
GOOGLE_OAUTH_REDIRECT_URI = "http://localhost:8501/"

# 신규 사용자 기본 조직 ID (Firestore Users)
DEFAULT_ORG_ID = "default-org"

# (선택) 배포된 앱 루트 URL — 초대 링크(Login?invite=코드) 안내에 전체 URL 표시용
# 예: https://your-app.streamlit.app  (끝 슬래시 없음)
# APP_BASE_URL = ""
